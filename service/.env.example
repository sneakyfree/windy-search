# Windy Search service — example env file. Copy to .env and fill in.

# --- Identity ---------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Server -----------------------------------------------------------
HOST=0.0.0.0
PORT=8500

# --- Redis (B.3 rate limit / B.10 cache / B.9 cost cap) ---------------
# Optional in B.1; required from B.3 onward.
# REDIS_URL=redis://localhost:6379/0

# --- Eternitas integration --------------------------------------------
ETERNITAS_BASE_URL=https://api.eternitas.ai
ETERNITAS_JWKS_URL=https://api.eternitas.ai/.well-known/eternitas-keys

# Required from B.2 onward — provision via the eternitas admin UI as a
# new platform whose webhook URL is https://search.windyword.ai/webhooks
# (or local equivalent) and whose name is "Windy Search". The plaintext
# key is shown ONCE on creation; after that only the bcrypt hash is in
# the eternitas DB. Store this key in your secrets manager.
# ETERNITAS_PLATFORM_API_KEY=et_plt_REPLACE_WITH_REAL_KEY

# --- Search backends --------------------------------------------------
# Required from B.4 onward. Without it, B.4 falls back to DuckDuckGo
# (lower-quality results, no commercial use).
# BRAVE_SEARCH_API_KEY=

# --- B.6 Browserbase (deferred until its codon) -----------------------
# BROWSERBASE_API_KEY=
# BROWSERBASE_PROJECT_ID=

# --- B.7 Claude vision (deferred) -------------------------------------
# ANTHROPIC_API_KEY=

# --- B.9 Cost caps ----------------------------------------------------
MONTHLY_COST_CAP_USD_DEFAULT=5.0
MONTHLY_COST_WARNING_PCT=0.80
