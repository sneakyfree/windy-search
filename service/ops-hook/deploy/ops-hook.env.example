# windy-search ops-hook — systemd unit env (install to /etc/windy-search-ops-hook.env, 0600).
# Values verified against SUBSTRATE.md (consolidated EC2 54.88.113.79, 2026-05-26 capture).
# ⚠️ Re-verify OPS_HOOK_IMAGE_REF on the host before install:
#     cd /opt/windy-search/deploy-prod && docker compose -p windysearch-prod images

OPS_HOOK_TOKEN=CHANGME_openssl_rand_base64_33
OPS_HOOK_PRODUCT=windy-search
OPS_HOOK_WORKDIR=/opt/windy-search/deploy-prod
OPS_HOOK_COMPOSE_CMD=docker compose -p windysearch-prod --env-file .env.production
OPS_HOOK_SERVICE=search-api
OPS_HOOK_IMAGE_REF=windy-search-api:local
OPS_HOOK_ENV_FILE=/opt/windy-search/deploy-prod/.env.production
# Provider-key class ONLY — never the hook token, DATABASE_URL, REDIS_URL, or signing secrets.
OPS_HOOK_CONFIG_ALLOWLIST=BRAVE_SEARCH_API_KEY,GOOGLE_SEARCH_API_KEY,GOOGLE_CSE_ID,LOG_LEVEL
# Patient is host-bound at 8510 (container 8500) per SUBSTRATE port table.
OPS_HOOK_PATIENT_URL=http://127.0.0.1:8510
# Stateless service — no migrate step (leave OPS_HOOK_MIGRATE_CMD unset).
# Consolidated host runs several hooks: search=8901 (pick unique per platform).
OPS_HOOK_BIND=127.0.0.1
OPS_HOOK_PORT=8901
